{
  "name": "nuxt-app",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "start": "nuxt start",
    "lint": "eslint --ext .js,.vue --ignore-path .eslintignore .",
    "lint:fix": "eslint --fix --ext .js,.vue --ignore-path .eslintignore .",
    "format": "prettier --write \"**/*.{js,vue,json,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,vue,json,scss,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@nuxtjs/composition-api": "^0.34.0",
    "nuxt": "^2.17.3",
    "vue": "^2.7.14",
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@nuxtjs/style-resources": "^1.2.2",
    "@vue/test-utils": "^1.3.6",
    "babel-jest": "^26.6.3",
    "jest": "^26.6.3",
    "jest-environment-jsdom-sixteen": "^1.0.3",
    "sass": "^1.91.0",
    "sass-loader": "^10.5.2",
    "vue-jest": "^4.0.1"
  }
}
